---
const navItems = [
  { label: "Home", href: "/" },
  { label: "Products", href: "/products" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];
---

<header class="site-header">
  <div class="header-spacer"></div>

  <div class="header-center">
    <a class="logo-link" href="/" aria-label="Jagsy Joy homepage">
      <img class="logo-image" src="/images/jagsy-joy-logo.png" alt="Jagsy Joy" />
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <a class="nav-link" href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>

  <div class="header-right">
    <a href="/account" class="header-icon" aria-label="Account">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
        <circle cx="12" cy="7" r="4"></circle>
      </svg>
    </a>
    <a href="/cart" class="header-icon" aria-label="Cart">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
        <path d="M3 6h18"></path>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: absolute !important;
    top: 42px !important;
    left: 0 !important;
    right: 0 !important;
    z-index: 100 !important;

    display: grid !important;
    grid-template-columns: 1fr auto 1fr !important;
    align-items: center !important;
    gap: 20px !important;

    width: 100% !important;
    box-sizing: border-box !important;
    padding: 24px 8% !important;

    background: transparent !important;
    border: none !important;
  }

  .header-spacer {
    display: flex !important;
    justify-content: flex-start !important;
  }

  .header-center {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    gap: 16px !important;
  }

  .header-right {
    display: flex !important;
    justify-content: flex-end !important;
    gap: 16px !important;
  }

  .header-icon {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: #17204A !important;
    transition: color 0.2s ease, transform 0.2s ease !important;
    text-decoration: none !important;
  }

  .header-icon:hover {
    color: #00C8FF !important;
    transform: scale(1.1) !important;
  }

  .logo-link {
    display: inline-flex !important;
    align-items: center !important;
    text-decoration: none !important;
    flex: 0 0 auto !important;
  }

  .logo-image {
    display: block !important;
    width: 220px !important;
    max-width: 220px !important;
    height: auto !important;
    object-fit: contain !important;
    filter: drop-shadow(0 10px 18px rgba(36, 31, 43, 0.15)) !important;
  }

  .site-nav {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 8px !important;
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    box-shadow: none !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }

  .nav-link {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;

    color: #17204A !important;
    text-decoration: none !important;
    font-weight: 800 !important;
    font-size: 15px !important;
    line-height: 1 !important;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.8) !important;

    padding: 10px 14px !important;
    position: relative !important;

    transition:
      color 0.2s ease,
      transform 0.2s ease !important;
  }

  .nav-link::after {
    content: '' !important;
    position: absolute !important;
    bottom: 2px !important;
    left: 14px !important;
    right: 14px !important;
    height: 2px !important;
    background: #00C8FF !important;
    transform: scaleX(0) !important;
    transition: transform 0.2s ease !important;
    transform-origin: center !important;
  }

  .nav-link:hover {
    color: #00C8FF !important;
    transform: translateY(-1px) !important;
  }

  .nav-link:hover::after {
    transform: scaleX(1) !important;
  }

  @media (max-width: 1024px) {
    .site-header {
      padding: 20px 5% !important;
    }
    
    .logo-image {
      width: 180px !important;
    }
  }

  @media (max-width: 800px) {
    .site-header {
      top: 38px !important;
      grid-template-columns: 1fr auto !important;
      grid-template-rows: auto auto !important;
      gap: 16px !important;
      padding: 18px 6% !important;
    }

    .header-spacer {
      display: none !important;
    }

    .header-right {
      order: 1 !important;
      grid-column: 2 !important;
    }

    .header-center {
      grid-column: span 2 !important;
      order: 2 !important;
      width: 100% !important;
    }

    .logo-image {
      width: 160px !important;
      max-width: 160px !important;
    }

    .site-nav {
      gap: 2px !important;
      flex-wrap: wrap !important;
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      width: 100% !important;
      box-sizing: border-box !important;
    }

    .nav-link {
      font-size: 13px !important;
      padding: 8px 10px !important;
      flex: 1 1 auto !important;
    }

    .nav-link::after {
      bottom: 0px !important;
      left: 10px !important;
      right: 10px !important;
    }
  }
</style>
