---
const { product } = Astro.props;
---

<article class="product-card">
  <a class="image-wrap" href={`/products/${product.slug}`} aria-label={`View ${product.name}`}>
    <img class="product-image" src={product.image} alt={product.name} />
  </a>

  <div class="card-content">
    <p class="category">{product.category}</p>
    <h3>{product.name}</h3>
    <p class="description">{product.shortDescription}</p>

    <div class="card-footer">
      <p class="price">{product.price}</p>
      <a class="view-link" href={`/products/${product.slug}`}>View Product</a>
    </div>
  </div>
</article>

<style>
  .product-card {
    background: #ffffff;
    border: 1px solid #D1EFFF;
    border-radius: 32px;
    padding: 18px;
    box-shadow: 0 12px 34px rgba(23, 32, 74, 0.04);
    overflow: hidden;
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      border-color 0.22s ease;
  }

  .product-card:hover {
    transform: translateY(-6px);
    border-color: #00C8FF;
    box-shadow: 0 22px 58px rgba(23, 32, 74, 0.08);
  }

  .image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 26px;
    overflow: hidden;
    background: #ffffff;
    border: 1px solid rgba(209, 239, 255, 0.9);
    text-decoration: none;
  }

  .product-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    padding: 10px;
    box-sizing: border-box;
  }

  .card-content {
    padding: 20px 4px 4px;
  }

  .category {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 13px;
    font-weight: 900;
    color: #17204A;
    margin: 0 0 12px;
  }

  h3 {
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #17204A;
    margin: 0 0 12px;
    font-weight: 900;
  }

  .description {
    color: #5f526b;
    line-height: 1.65;
    font-size: 16px;
    margin: 0;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-top: 22px;
  }

  .price {
    color: #17204A;
    font-size: 24px;
    font-weight: 950;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .view-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 16px;
    border-radius: 999px;
    background: linear-gradient(135deg, #00C8FF, #18D6C9);
    color: white;
    text-decoration: none;
    font-weight: 900;
    font-size: 14px;
    box-shadow: 0 12px 26px rgba(0, 200, 255, 0.22);
    white-space: nowrap;
  }

  .view-link:hover {
    opacity: 0.92;
  }

  @media (max-width: 520px) {
    .card-footer {
      flex-direction: column;
      align-items: stretch;
    }

    .view-link {
      width: 100%;
    }
  }
</style>