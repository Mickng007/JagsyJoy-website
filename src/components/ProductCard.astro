---
const { product } = Astro.props;
---

<article class="product-card">
  <a class="image-wrap" href={`/products/${product.slug}`} aria-label={`View ${product.name}`}>
    <img class="product-image" src={product.image} alt={product.name} />
  </a>

  <div class="card-content">
    <p class="category">{product.category}</p>
    <h3>{product.name}</h3>
    <p class="description">{product.shortDescription}</p>

    <div class="card-footer">
      <p class="price">{product.price}</p>
      <a class="view-link" href={`/products/${product.slug}`}>View Product</a>
    </div>
  </div>
</article>

<style>
  .product-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 247, 252, 0.98));
    border: 1px solid #f3d6e4;
    border-radius: 32px;
    padding: 18px;
    box-shadow: 0 20px 50px rgba(255, 79, 163, 0.12);
    overflow: hidden;
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      border-color 0.22s ease;
  }

  .product-card:hover {
    transform: translateY(-6px);
    border-color: #ff9dcc;
    box-shadow: 0 28px 70px rgba(125, 92, 255, 0.16);
  }

  .image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 26px;
    overflow: hidden;
    background:
      radial-gradient(circle at 20% 12%, rgba(255, 125, 184, 0.18), transparent 30%),
      radial-gradient(circle at 88% 16%, rgba(69, 199, 244, 0.18), transparent 28%),
      #ffffff;
    border: 1px solid rgba(243, 214, 228, 0.9);
    text-decoration: none;
  }

  .product-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    padding: 10px;
    box-sizing: border-box;
  }

  .card-content {
    padding: 20px 4px 4px;
  }

  .category {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 12px;
    font-weight: 900;
    color: #ff4fa3;
    margin: 0 0 12px;
  }

  h3 {
    font-size: 28px;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: #241f2b;
    margin: 0 0 12px;
  }

  .description {
    color: #6d6475;
    line-height: 1.65;
    font-size: 16px;
    margin: 0;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-top: 22px;
  }

  .price {
    color: #241f2b;
    font-size: 24px;
    font-weight: 950;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .view-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 16px;
    border-radius: 999px;
    background: linear-gradient(135deg, #ff7db8, #7d5cff);
    color: white;
    text-decoration: none;
    font-weight: 900;
    font-size: 14px;
    box-shadow: 0 12px 26px rgba(255, 79, 163, 0.22);
    white-space: nowrap;
  }

  .view-link:hover {
    opacity: 0.92;
  }

  @media (max-width: 520px) {
    .card-footer {
      flex-direction: column;
      align-items: stretch;
    }

    .view-link {
      width: 100%;
    }
  }
</style>