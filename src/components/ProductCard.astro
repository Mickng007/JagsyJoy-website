---
const { product } = Astro.props;
---

<article class="product-card">
  <div class="image-wrap">
    <img class="product-image" src={product.image} alt={product.name} />
  </div>

  <p class="category">{product.category}</p>
  <h3>{product.name}</h3>
  <p>{product.shortDescription}</p>

  <a href={`/products/${product.slug}`}>View Product</a>
</article>

<style>
  .product-card {
    background: white;
    border: 1px solid #eadfce;
    border-radius: 28px;
    padding: 22px;
    box-shadow: 0 18px 40px rgba(47, 42, 36, 0.08);
    overflow: hidden;
  }

.image-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 22px;
  overflow: hidden;
  background: white;
  margin-bottom: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px;
  box-sizing: border-box;
 }

.product-image {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: contain;
 }

  .category {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 13px;
    font-weight: 800;
    color: #c77b4f;
  }

  .product-card h3 {
    font-size: 24px;
    margin: 8px 0 10px;
  }

  .product-card p {
    color: #6b6258;
    line-height: 1.7;
    font-size: 17px;
  }

  .product-card a {
    display: inline-block;
    margin-top: 12px;
    color: #2f2a24;
    font-weight: 800;
  }
</style>