---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';

const siteUrl = "https://jagsyjoy-website.pages.dev";
const canonicalUrl = `${siteUrl}/about`;
const ogImage = `${siteUrl}/images/blog-1.jpg`;

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Jagsy Joy",
  url: canonicalUrl,
  description:
    "Jagsy Joy creates playful learning toys that support curiosity, fine motor skills, independent play, and screen-free discovery for toddlers.",
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>About Jagsy Joy | Thoughtful Learning Toys for Toddlers</title>
    <meta
      name="description"
      content="Learn about Jagsy Joy, a playful toddler toy brand creating busy boards for screen-free learning, practical life skills, and curious little hands."
    />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content="About Jagsy Joy | Thoughtful Learning Toys for Toddlers" />
    <meta property="og:description" content="Learn about Jagsy Joy, a playful toddler toy brand creating busy boards for screen-free learning, practical life skills, and curious little hands." />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content="About Jagsy Joy | Thoughtful Learning Toys for Toddlers" />
    <meta property="twitter:description" content="Learn about Jagsy Joy, a playful toddler toy brand creating busy boards for screen-free learning, practical life skills, and curious little hands." />
    <meta property="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />
  </head>

  <body>
    <AnnouncementBar />
    <Header />

    <main>
      <section class="about-hero">
        <div class="about-hero-bg"></div>
        <div class="about-hero-overlay"></div>

        <div class="about-hero-content">
          <h1>About Jagsy Joy</h1>
          <p>Thoughtful learning toys for curious little hands.</p>
        </div>
      </section>

      <section class="about-content">
        <div class="breadcrumb">
          <a href="/">Home</a>
          <span>›</span>
          <span>About Jagsy Joy</span>
        </div>

        <div class="story-heading">
          <p class="eyebrow">Our Story</p>
          <h2>About Jagsy Joy</h2>
        </div>

        <div class="story-copy">
          <p>
            At Jagsy Joy, we believe childhood should feel magical, curious, and
            full of discovery. We create playful learning toys that help spark
            curiosity, support growing minds, and turn everyday playtime into
            meaningful moments of development.
          </p>

          <p>
            Our flagship product, the Toddler Busy Board, is more than just a toy.
            It is a hands-on world of wonder designed to help little ones practice
            fine motor skills, build independence, explore colors and textures, and
            enjoy screen-free play.
          </p>

          <p>
            Every Jagsy Joy toy is made with one simple goal: to make learning feel
            like play.
          </p>
        </div>
      </section>

      <section class="purpose-section">
        <div class="purpose-heading">
          <p class="eyebrow">Our Purpose</p>
          <h2>Learning should feel natural.</h2>
        </div>

        <div class="purpose-copy">
          <p>
            We believe toddlers learn best through hands-on discovery. Our toys are
            designed to support fine motor skills, focus, independent play, and
            everyday confidence through simple, screen-free activities.
          </p>

          <p>
            From busy boards to travel-friendly activity toys, Jagsy Joy helps
            families bring calm, purposeful play into daily routines.
          </p>
        </div>
      </section>

      <section class="feature-grid">
        <article class="feature-card">
          <div class="feature-icon">✨</div>
          <h3>Screen-Free Play</h3>
          <p>Simple activities that help children stay engaged without screens.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon">🙌</div>
          <h3>Everyday Skills</h3>
          <p>Designed to help toddlers practice real-life movements and tasks.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon">✈️</div>
          <h3>Travel Friendly</h3>
          <p>Made for quiet play at home, in the car, or while traveling.</p>
        </article>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #17204A;
    background: #EAFBFF;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 10% 10%, rgba(0, 200, 255, 0.08), transparent 30%),
      radial-gradient(circle at 90% 4%, rgba(24, 214, 201, 0.08), transparent 26%),
      linear-gradient(180deg, #EAFBFF 0%, #F4FDFF 52%, #EEE8FF 100%);
  }

  .about-hero {
    position: relative;
    min-height: 460px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 130px 8% 80px;
    box-sizing: border-box;
    overflow: hidden;
    isolation: isolate;
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url("/images/jagsy-joy-hero.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 0;
    transform: scale(1.02);
  }

  .about-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(0, 200, 255, 0.24) 0%,
        rgba(23, 32, 74, 0.22) 42%,
        rgba(234, 251, 255, 0.32) 100%
      ),
      rgba(23, 32, 74, 0.2);
    z-index: 1;
  }

  .about-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 780px;
    color: white;
  }

  .about-hero h1 {
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
    color: #ffffff;
    font-weight: 900;
    text-shadow: none;
  }

  .about-hero p {
    font-size: 16px;
    line-height: 1.6;
    margin: 0;
    color: rgba(255, 255, 255, 0.94);
    text-shadow: none;
  }

  .about-content {
    padding: 82px 8% 48px;
    background: #F4FDFF;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    color: #5f526b;
    font-size: 14px;
    margin-bottom: 20px;
  }

  .breadcrumb a {
    color: #17204A;
    text-decoration: none;
    font-weight: 800;
  }

  .story-heading {
    text-align: center;
    max-width: 860px;
    margin: 0 auto 24px;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 13px;
    font-weight: 900;
    color: #17204A;
    margin: 0 0 12px;
  }

  .story-heading h2,
  .purpose-heading h2 {
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0;
    color: #17204A;
    font-weight: 900;
  }

  .story-copy {
    max-width: 1040px;
    margin: 0 auto;
    text-align: center;
  }

  .story-copy p {
    color: #5f526b;
    font-size: 16px;
    line-height: 1.65;
    margin: 0 0 24px;
  }

  .purpose-section {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 72px;
    align-items: start;
    padding: 78px 8%;
    background: #EAFBFF;
  }

  .purpose-heading {
    max-width: 520px;
  }

  .purpose-copy {
    max-width: 760px;
  }

  .purpose-copy p {
    color: #5f526b;
    font-size: 16px;
    line-height: 1.65;
    margin: 0 0 24px;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 28px;
    padding: 0 8% 96px;
    background: #EAFBFF;
  }

  .feature-card {
    background:
      radial-gradient(circle at 100% 0%, rgba(0, 200, 255, 0.08), transparent 32%),
      #ffffff;
    border: 1px solid #D1EFFF;
    border-radius: 28px;
    padding: 34px;
    box-shadow: 0 20px 56px rgba(0, 200, 255, 0.06);
  }

  .feature-icon {
    font-size: 28px;
    margin-bottom: 16px;
  }

  .feature-card h3 {
    color: #17204A;
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
    font-weight: 900;
  }

  .feature-card p {
    color: #5f526b;
    font-size: 16px;
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 920px) {
    .about-hero {
      min-height: 360px;
      padding: 130px 6% 64px;
    }

    .about-logo {
      width: 150px;
    }

    .purpose-section {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 64px 6%;
    }

    .feature-grid {
      grid-template-columns: 1fr;
      padding: 0 6% 72px;
    }

    .about-content {
      padding: 64px 6% 38px;
    }

    .story-copy {
      text-align: left;
    }

    .breadcrumb,
    .story-heading {
      text-align: center;
      justify-content: center;
    }
  }
</style>