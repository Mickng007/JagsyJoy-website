  }

  .dot {
    opacity: 0.45;
  }

  .cover-section {
    padding: 0 8%;
    margin-bottom: 60px;
  }

  .cover-image-container {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    border-radius: 32px;
