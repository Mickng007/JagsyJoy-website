---

import products from '../../data/products.json';

import Header from '../../components/Header.astro';

import Footer from '../../components/Footer.astro';

export function getStaticPaths() {

  return products.map((product) => ({

    params: { slug: product.slug },

    props: { product },

  }));

}

const { product } = Astro.props;

const galleryImages = product.images && product.images.length > 0 ? product.images : [product.image];

const productSchema = {

  "@context": "https://schema.org",

  "@type": "Product",

  name: product.name,

  brand: {

    "@type": "Brand",

    name: product.brand,

  },

  description: product.shortDescription,

  image: galleryImages,

  category: product.category,

  offers: {

    "@type": "Offer",

    priceCurrency: "USD",

    price: product.price?.replace("$", ""),

    availability: "https://schema.org/InStock",

  },

};

---

<html lang="en">

  <head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width" />

    <title>{product.name} | Jagsy Joy</title>

    <meta name="description" content={product.shortDescription} />

    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

  </head>

  <body>

    <Header />

    <main>

      <section class="product-hero">

        <div class="gallery">

          <div class="main-image-wrap">

            <img

              id="mainProductImage"

              class="main-product-image"

              src={galleryImages[0]}

              alt={product.name}

            />

          </div>

          <div class="thumbnail-grid" aria-label={`${product.name} image gallery`}>

            {galleryImages.map((image, index) => (

              <button

                class={`thumbnail-button ${index === 0 ? 'active' : ''}`}

                type="button"

                data-image={image}

                aria-label={`View ${product.name} image ${index + 1}`}

              >

                <img src={image} alt={`${product.name} thumbnail ${index + 1}`} />

              </button>

            ))}

          </div>

        </div>

        <div class="product-info">

          <p class="eyebrow">{product.category}</p>

          <h1>{product.name}</h1>

          <p class="intro">{product.shortDescription}</p>

          <p class="price">{product.price}</p>

          <div class="details">

            <p><strong>Brand:</strong> {product.brand}</p>

            <p><strong>Age Range:</strong> {product.ageRange}</p>

            <p><strong>Material:</strong> {product.material}</p>

          </div>

          <div class="purchase-row">

            <div class="quantity-selector" aria-label="Quantity selector">

              <button type="button" id="decreaseQty">−</button>

              <span id="quantityValue">1</span>

              <button type="button" id="increaseQty">+</button>

            </div>

            <button class="add-to-cart" type="button">

              Add to Cart

            </button>

          </div>

          <p class="cart-note">

            Prototype button only. Checkout connection can be added later.

          </p>

        </div>

      </section>

      <section class="section">

        <h2>Product Overview</h2>

        <p>{product.longDescription}</p>

      </section>

      <section class="section">

        <h2>Product Details</h2>

        <ul>

          {(product.details || product.benefits).map((detail) => (

            <li>{detail}</li>

          ))}

        </ul>

      </section>

      <section class="section">

        <h2>Key Benefits</h2>

        <ul>

          {product.benefits.map((benefit) => (

            <li>{benefit}</li>

          ))}

        </ul>

      </section>

    </main>

    <Footer />

    <script>

      const mainImage = document.querySelector("#mainProductImage");

      const thumbnailButtons = document.querySelectorAll(".thumbnail-button");

      thumbnailButtons.forEach((button) => {

        button.addEventListener("click", () => {

          const image = button.getAttribute("data-image");

          if (mainImage && image) {

            mainImage.setAttribute("src", image);

          }

          thumbnailButtons.forEach((item) => item.classList.remove("active"));

          button.classList.add("active");

        });

      });

      const decreaseButton = document.querySelector("#decreaseQty");

      const increaseButton = document.querySelector("#increaseQty");

      const quantityValue = document.querySelector("#quantityValue");

      let quantity = 1;

      decreaseButton?.addEventListener("click", () => {

        quantity = Math.max(1, quantity - 1);

        if (quantityValue) quantityValue.textContent = String(quantity);

      });

      increaseButton?.addEventListener("click", () => {

        quantity += 1;

        if (quantityValue) quantityValue.textContent = String(quantity);

      });

    </script>

  </body>

</html>

<style>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #241f2b;
    background: #fff7f2;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 10% 10%, rgba(255, 125, 184, 0.12), transparent 30%),
      radial-gradient(circle at 90% 4%, rgba(69, 199, 244, 0.12), transparent 26%),
      linear-gradient(180deg, #fff7f2 0%, #fff2f8 50%, #f4fbff 100%);
  }

  .product-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
    padding: 120px 8% 80px;
  }

  .gallery {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .main-image-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 36px;
    overflow: hidden;
    background: white;
    border: 1px solid #f3d6e4;
    box-shadow: 0 18px 40px rgba(255, 79, 163, 0.08);
  }

  .main-product-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .thumbnail-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .thumbnail-button {
    border: 1px solid #f3d6e4;
    background: white;
    border-radius: 18px;
    padding: 8px;
    aspect-ratio: 1 / 1;
    cursor: pointer;
    overflow: hidden;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .thumbnail-button:hover,
  .thumbnail-button.active {
    border-color: #ff4fa3;
    box-shadow: 0 10px 24px rgba(255, 79, 163, 0.12);
    transform: translateY(-2px);
  }

  .thumbnail-button img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-info {
    padding-top: 28px;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 13px;
    font-weight: 900;
    color: #ff4fa3;
    margin: 0;
  }

  h1 {
    font-size: clamp(44px, 6vw, 82px);
    line-height: 0.95;
    letter-spacing: -0.05em;
    margin: 12px 0 24px;
    color: #241f2b;
  }

  h2 {
    font-size: clamp(32px, 4vw, 42px);
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    color: #241f2b;
  }

  .intro {
    font-size: 20px;
    line-height: 1.6;
    color: #6d6475;
  }

  .price {
    font-size: 38px;
    line-height: 1;
    font-weight: 900;
    letter-spacing: -0.04em;
    margin: 28px 0;
    color: #ff4fa3;
  }

  .details {
    background: white;
    border: 1px solid #f3d6e4;
    border-radius: 24px;
    padding: 20px;
    margin: 28px 0;
    box-shadow: 0 10px 30px rgba(255, 79, 163, 0.05);
  }

  .details p {
    margin: 8px 0;
    color: #6d6475;
  }

  .purchase-row {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }

  .quantity-selector {
    display: flex;
    align-items: center;
    border: 1px solid #f3d6e4;
    border-radius: 16px;
    overflow: hidden;
    background: white;
    height: 54px;
  }

  .quantity-selector button {
    width: 50px;
    height: 54px;
    border: 0;
    background: white;
    color: #241f2b;
    font-size: 22px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .quantity-selector button:hover {
    background: #fff2f8;
  }

  .quantity-selector span {
    min-width: 42px;
    text-align: center;
    font-weight: 800;
    color: #241f2b;
  }

  .add-to-cart {
    height: 54px;
    border: 0;
    border-radius: 16px;
    background: linear-gradient(135deg, #ff7db8, #7d5cff);
    color: white;
    padding: 0 32px;
    font-weight: 900;
    cursor: pointer;
    font-size: 16px;
    box-shadow: 0 14px 30px rgba(255, 79, 163, 0.24);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .add-to-cart:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(125, 92, 255, 0.28);
  }

  .cart-note {
    color: #6d6475;
    font-size: 14px;
    margin-top: 16px;
    opacity: 0.8;
  }

  .section {
    padding: 40px 8% 60px;
    max-width: 980px;
  }

  .section p,
  li {
    color: #6d6475;
    font-size: 18px;
    line-height: 1.7;
  }

  li {
    margin-bottom: 12px;
  }

  @media (max-width: 900px) {
    .product-hero {
      grid-template-columns: 1fr;
      gap: 40px;
      padding-top: 100px;
    }
  }
</style>