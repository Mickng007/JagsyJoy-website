---
import products from '../../data/products.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  brand: {
    "@type": "Brand",
    name: product.brand,
  },
  description: product.shortDescription,
  image: product.image,
  category: product.category,
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{product.name} | Jagsy Joy</title>
    <meta name="description" content={product.shortDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </head>

  <body>
    <Header />

    <main>
      <section class="product-hero">
        <div class="image-wrap">
          <img class="product-image" src={product.image} alt={product.name} />
        </div>

        <div class="product-info">
          <p class="eyebrow">{product.category}</p>
          <h1>{product.name}</h1>
          <p class="intro">{product.shortDescription}</p>

          <div class="details">
            <p><strong>Brand:</strong> {product.brand}</p>
            <p><strong>Age Range:</strong> {product.ageRange}</p>
            <p><strong>Material:</strong> {product.material}</p>
          </div>

          <a class="button" href="/products">Back to Products</a>
        </div>
      </section>

      <section class="section">
        <h2>Product Overview</h2>
        <p>{product.longDescription}</p>
      </section>

      <section class="section">
        <h2>Key Benefits</h2>
        <ul>
          {product.benefits.map((benefit) => (
            <li>{benefit}</li>
          ))}
        </ul>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family: Inter, system-ui, sans-serif;
    color: #2f2a24;
    background: #fffaf3;
  }

  body {
    margin: 0;
    background: #fffaf3;
  }

  .product-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding: 80px 8%;
  }

  .image-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 36px;
    overflow: hidden;
    background: white;
    box-shadow: 0 18px 40px rgba(47, 42, 36, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 18px;
    box-sizing: border-box;
  }

  .product-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 13px;
    font-weight: 800;
    color: #c77b4f;
  }

  h1 {
    font-size: clamp(44px, 6vw, 82px);
    line-height: 0.95;
    letter-spacing: -0.05em;
    margin: 12px 0 24px;
  }

  h2 {
    font-size: 36px;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }

  .intro {
    font-size: 20px;
    line-height: 1.6;
    color: #6b6258;
  }

  .details {
    background: white;
    border: 1px solid #eadfce;
    border-radius: 24px;
    padding: 20px;
    margin: 28px 0;
  }

  .details p {
    margin: 8px 0;
    color: #6b6258;
  }

  .button {
    display: inline-block;
    padding: 14px 22px;
    border-radius: 999px;
    background: #2f2a24;
    color: white;
    text-decoration: none;
    font-weight: 800;
  }

  .section {
    padding: 30px 8% 70px;
    max-width: 900px;
  }

  .section p,
  li {
    color: #6b6258;
    font-size: 18px;
    line-height: 1.7;
  }

  li {
    margin-bottom: 10px;
  }

  @media (max-width: 800px) {
    .product-hero {
      grid-template-columns: 1fr;
    }
  }
</style>