---
import products from '../../data/products.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Products | Jagsy Joy</title>
    <meta
      name="description"
      content="Explore Jagsy Joy toddler learning toys, including busy boards and screen-free learning toys."
    />
  </head>

  <body>
    <Header />

    <main>
      <section class="hero">
        <p class="eyebrow">Our Products</p>
        <h1>Learning toys made for curious little hands.</h1>
        <p>
          Explore screen-free toddler toys designed for early learning, quiet play,
          travel time, and everyday skill-building.
        </p>
      </section>

      <section class="product-grid">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #17204A;
    background: #EAFBFF;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 10% 10%, rgba(0, 200, 255, 0.08), transparent 30%),
      radial-gradient(circle at 90% 4%, rgba(24, 214, 201, 0.08), transparent 26%),
      linear-gradient(180deg, #EAFBFF 0%, #F4FDFF 50%, #EEE8FF 100%);
  }

  .hero {
    padding: 210px 8% 90px;
    max-width: 900px;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 13px;
    font-weight: 900;
    color: #17204A;
    margin: 0 0 16px;
  }

  h1 {
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
    color: #17204A;
    font-weight: 900;
    text-shadow: none;
  }

  .hero p {
    color: #5f526b;
    font-size: 16px;
    line-height: 1.65;
    max-width: 620px;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 430px));
    justify-content: center;
    gap: 32px;
    padding: 40px 8% 90px;
  }

  @media (max-width: 800px) {
    .hero {
      padding: 150px 8% 60px;
    }
    h1 {
      font-size: 28px;
      letter-spacing: -0.02em;
    }
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>