---
import products from '../../data/products.json';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Products | Jagsy Joy</title>
    <meta
      name="description"
      content="Explore Jagsy Joy toddler learning toys, including busy boards and screen-free learning toys."
    />
  </head>

  <body>
    <Header />

    <main>
      <section class="hero">
        <p class="eyebrow">Our Products</p>
        <h1>Learning toys made for curious little hands.</h1>
        <p>
          Explore screen-free toddler toys designed for early learning, quiet play,
          travel time, and everyday skill-building.
        </p>
      </section>

      <section class="product-grid">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #241f2b;
    background: #fff7f2;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 10% 10%, rgba(255, 125, 184, 0.12), transparent 30%),
      radial-gradient(circle at 90% 4%, rgba(69, 199, 244, 0.12), transparent 26%),
      linear-gradient(180deg, #fff7f2 0%, #fff2f8 50%, #f4fbff 100%);
  }

  .hero {
    padding: 120px 8% 40px;
    max-width: 900px;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 13px;
    font-weight: 900;
    color: #ff4fa3;
    margin: 0 0 16px;
  }

  h1 {
    font-size: clamp(44px, 6vw, 78px);
    line-height: 0.95;
    letter-spacing: -0.05em;
    margin: 0 0 24px;
    color: #ff4fa3;
    text-shadow:
      0 2px 0 white,
      0 4px 0 rgba(125, 92, 255, 0.2);
  }

  .hero p {
    color: #6d6475;
    font-size: 20px;
    line-height: 1.6;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 430px));
    justify-content: center;
    gap: 32px;
    padding: 40px 8% 90px;
  }

  @media (max-width: 800px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>