const siteUrl = "https://jagsyjoy-website.pages.dev";
const canonicalUrl = `${siteUrl}/products`;
const ogImage = `${siteUrl}/images/blog-1.jpg`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Toddler Busy Boards | Jagsy Joy</title>
    <meta
      name="description"
      content="Explore Jagsy Joy toddler busy boards made for hands-on learning, travel-friendly play, fine motor skills, and everyday discovery."
    />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content="Toddler Busy Boards | Jagsy Joy" />
    <meta property="og:description" content="Explore Jagsy Joy toddler busy boards made for hands-on learning, travel-friendly play, fine motor skills, and everyday discovery." />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content="Toddler Busy Boards | Jagsy Joy" />
    <meta property="twitter:description" content="Explore Jagsy Joy toddler busy boards made for hands-on learning, travel-friendly play, fine motor skills, and everyday discovery." />
    <meta property="twitter:image" content={ogImage} />
  </head>

  <body>
    <Header />

    <main>
      <section class="hero">
        <p class="eyebrow">Our Products</p>
        <h1>Learning toys made for curious little hands.</h1>
        <p>
          Explore screen-free toddler toys designed for early learning, quiet play,
          travel time, and everyday skill-building.
        </p>
      </section>

      <section class="product-grid">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #17204A;
    background: #EAFBFF;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 10% 10%, rgba(0, 200, 255, 0.08), transparent 30%),
      radial-gradient(circle at 90% 4%, rgba(24, 214, 201, 0.08), transparent 26%),
      linear-gradient(180deg, #EAFBFF 0%, #F4FDFF 50%, #EEE8FF 100%);
  }

  .hero {
    padding: 210px 8% 90px;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 13px;
    font-weight: 900;
    color: #17204A;
    margin: 0 0 16px;
  }

  h1 {
    font-size: clamp(42px, 5vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.055em;
    margin: 0 0 24px;
    color: #17204A;
    font-weight: 900;
    text-shadow: none;
  }

  .hero p {
    color: #5f526b;
    font-size: 16px;
    line-height: 1.7;
    max-width: 760px;
    margin: 0 auto;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 48px;
    padding: 40px 8% 120px;
    width: 100%;
    max-width: 1520px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  @media (max-width: 900px) {
    .hero {
      padding: 150px 8% 60px;
    }
    h1 {
      font-size: clamp(34px, 9vw, 48px);
      line-height: 1;
    }
    .product-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>