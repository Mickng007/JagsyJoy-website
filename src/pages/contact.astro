---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Contact | Jagsy Joy</title>
    <meta
      name="description"
      content="Contact Jagsy Joy to learn more about our toddler learning toys, busy boards, busy books, and travel-friendly activity toys."
    />
  </head>

  <body>
    <Header />

    <main>
      <section class="hero">
        <p class="eyebrow">Contact Us</p>
        <h1>Have a question about Jagsy Joy?</h1>
        <p>
          Reach out to learn more about our toddler learning toys, product
          collections, or partnership opportunities.
        </p>
      </section>

      <section class="contact-section">
        <div class="contact-card">
          <p class="eyebrow">Email</p>
          <h2>Let’s connect.</h2>
          <p>
            For product questions, wholesale inquiries, or general support, send
            us a message anytime.
          </p>

          <a class="button" href="mailto:qenterprises.design@gmail.com">
            Email Us
          </a>
        </div>

        <div class="info-card">
          <h3>What we can help with</h3>

          <ul>
            <li>Product information</li>
            <li>Retail or wholesale inquiries</li>
            <li>Brand partnership questions</li>
            <li>Customer support</li>
          </ul>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family: Inter, system-ui, sans-serif;
    color: #2f2a24;
    background: #fffaf3;
  }

  body {
    margin: 0;
    background: #fffaf3;
  }

  .hero {
    padding: 90px 8% 50px;
    max-width: 980px;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 13px;
    font-weight: 800;
    color: #c77b4f;
  }

  h1 {
    font-size: clamp(44px, 6vw, 82px);
    line-height: 0.95;
    letter-spacing: -0.05em;
    margin: 12px 0 24px;
  }

  h2 {
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 10px 0 18px;
  }

  h3 {
    font-size: 28px;
    margin: 0 0 18px;
  }

  .hero p,
  .contact-card p,
  li {
    color: #6b6258;
    font-size: 18px;
    line-height: 1.7;
  }

  .hero p {
    font-size: 21px;
    max-width: 720px;
  }

  .contact-section {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 24px;
    padding: 40px 8% 90px;
  }

  .contact-card,
  .info-card {
    background: white;
    border: 1px solid #eadfce;
    border-radius: 32px;
    padding: 36px;
    box-shadow: 0 18px 40px rgba(47, 42, 36, 0.08);
  }

  .button {
    display: inline-block;
    margin-top: 16px;
    padding: 14px 22px;
    border-radius: 999px;
    background: #2f2a24;
    color: white;
    text-decoration: none;
    font-weight: 800;
  }

  ul {
    padding-left: 20px;
    margin: 0;
  }

  li {
    margin-bottom: 10px;
  }

  @media (max-width: 800px) {
    .contact-section {
      grid-template-columns: 1fr;
    }
  }
</style>