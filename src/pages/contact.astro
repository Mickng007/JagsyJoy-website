---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const siteUrl = "https://jagsyjoy-website.pages.dev";
const canonicalUrl = `${siteUrl}/contact`;
const ogImage = `${siteUrl}/images/blog-1.jpg`;

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Jagsy Joy",
  url: canonicalUrl,
  description: "Contact Jagsy Joy for questions about busy boards, toddler learning toys, orders, product support, and general inquiries.",
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Contact Jagsy Joy | Toddler Learning Toys</title>
    <meta
      name="description"
      content="Contact Jagsy Joy for questions about busy boards, toddler learning toys, orders, product support, and general inquiries."
    />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content="Contact Jagsy Joy | Toddler Learning Toys" />
    <meta property="og:description" content="Contact Jagsy Joy for questions about busy boards, toddler learning toys, orders, product support, and general inquiries." />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content="Contact Jagsy Joy | Toddler Learning Toys" />
    <meta property="twitter:description" content="Contact Jagsy Joy for questions about busy boards, toddler learning toys, orders, product support, and general inquiries." />
    <meta property="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />
  </head>

  <body>
    <Header />

    <main>
      <section class="hero">
        <p class="eyebrow">Contact Us</p>
        <h1>Have a question about Jagsy Joy?</h1>
        <p>
          Reach out to learn more about our toddler learning toys, product
          collections, or partnership opportunities.
        </p>
      </section>

      <section class="contact-section">
        <div class="contact-card">
          <p class="eyebrow">Email</p>
          <h2>Let’s connect.</h2>
          <p>
            For product questions, wholesale inquiries, or general support, send
            us a message anytime.
          </p>

          <a class="button" href="mailto:qenterprises.design@gmail.com">
            Email Us
          </a>
        </div>

        <div class="info-card">
          <h3>What we can help with</h3>

          <ul>
            <li>Product information</li>
            <li>Retail or wholesale inquiries</li>
            <li>Brand partnership questions</li>
            <li>Customer support</li>
          </ul>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family: Inter, system-ui, sans-serif;
    color: #17204A;
    background: #EAFBFF;
  }

  body {
    margin: 0;
    background: #EAFBFF;
  }

  .hero {
    padding: 210px 8% 50px;
    max-width: 980px;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 13px;
    font-weight: 900;
    color: #17204A;
  }

  h1 {
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 12px 0 24px;
    color: #17204A;
    font-weight: 900;
  }

  h2 {
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 10px 0 18px;
    color: #17204A;
    font-weight: 900;
  }

  h3 {
    font-size: 22px;
    margin: 0 0 18px;
    color: #17204A;
    font-weight: 900;
  }

  .hero p,
  .contact-card p,
  li {
    color: #5f526b;
    font-size: 16px;
    line-height: 1.7;
  }

  .hero p {
    font-size: 16px;
    max-width: 720px;
  }

  .contact-section {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 24px;
    padding: 40px 8% 90px;
  }

  .contact-card,
  .info-card {
    background: white;
    border: 1px solid #D1EFFF;
    border-radius: 32px;
    padding: 36px;
    box-shadow: 0 18px 40px rgba(0, 200, 255, 0.04);
  }

  .button {
    display: inline-block;
    margin-top: 16px;
    padding: 14px 22px;
    border-radius: 999px;
    background: #17204A;
    color: white;
    text-decoration: none;
    font-weight: 800;
  }

  ul {
    padding-left: 20px;
    margin: 0;
  }

  li {
    margin-bottom: 10px;
  }

  @media (max-width: 800px) {
    .contact-section {
      grid-template-columns: 1fr;
    }
  }
</style>