---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';

const cartSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Your Cart | Jagsy Joy",
  url: "http://localhost:4321/cart",
  description: "Review your selected Jagsy Joy toddler toys before checkout.",
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Cart | Jagsy Joy</title>
    <meta name="description" content="Review your Jagsy Joy toys before playtime begins." />
    <script type="application/ld+json" set:html={JSON.stringify(cartSchema)} />
  </head>

  <body>
    <AnnouncementBar />
    <Header />

    <main>
      <section class="hero">
        <p class="eyebrow">Your Cart</p>
        <h1>Your cart is waiting for playtime.</h1>
        <p class="hero-text">
          Review your selected Jagsy Joy toys before checkout.
        </p>
      </section>

      <section class="cart-content">
        <div class="container">
          <div class="empty-cart-card">
            <div class="empty-icon">🛒</div>
            <h2>Your cart is currently empty.</h2>
            <p>Start exploring our toddler learning toys to find the perfect gift for curious little hands.</p>
            <a href="/products" class="button primary">Explore Products</a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #17204A;
    background: #EAFBFF;
  }

  body {
    margin: 0;
    background: #EAFBFF;
  }

  .hero {
    padding: 210px 8% 60px;
    max-width: 900px;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 13px;
    font-weight: 900;
    color: #17204A;
    margin: 0 0 16px;
  }

  h1 {
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
    color: #17204A;
    font-weight: 900;
    text-shadow: none;
  }

  .hero-text {
    font-size: 16px;
    line-height: 1.6;
    color: #5f526b;
    max-width: 600px;
  }

  .cart-content {
    padding: 20px 0 120px;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 8%;
  }

  .empty-cart-card {
    background: white;
    border: 1px solid #D1EFFF;
    border-radius: 32px;
    padding: 80px 40px;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0, 200, 255, 0.04);
  }

  .empty-icon {
    font-size: 64px;
    margin-bottom: 32px;
  }

  .empty-cart-card h2 {
    font-size: 22px;
    margin-bottom: 16px;
    font-weight: 900;
    color: #17204A;
    line-height: 1.2;
  }

  .empty-cart-card p {
    color: #5f526b;
    font-size: 16px;
    line-height: 1.65;
    max-width: 500px;
    margin: 0 auto 40px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0 36px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 900;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .primary {
    background: linear-gradient(135deg, #00C8FF, #18D6C9);
    color: white;
    box-shadow: 0 14px 30px rgba(0, 200, 255, 0.2);
  }

  .button:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(0, 200, 255, 0.26);
  }

  @media (max-width: 900px) {
    .hero {
      padding-top: 150px;
    }
    
    .empty-cart-card {
      padding: 60px 24px;
    }
  }
</style>
