const siteUrl = "https://jagsyjoy-website.pages.dev";
const canonicalUrl = `${siteUrl}/blogs`;
const ogImage = `${siteUrl}/images/blog-1.jpg`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Jagsy Joy Blog | Toddler Learning & Screen-Free Play Ideas</title>
    <meta
      name="description"
      content="Read Jagsy Joy blog articles about toddler development, busy boards, fine motor skills, screen-free play, and practical life learning."
    />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content="Jagsy Joy Blog | Toddler Learning & Screen-Free Play Ideas" />
    <meta property="og:description" content="Read Jagsy Joy blog articles about toddler development, busy boards, fine motor skills, screen-free play, and practical life learning." />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content="Jagsy Joy Blog | Toddler Learning & Screen-Free Play Ideas" />
    <meta property="twitter:description" content="Read Jagsy Joy blog articles about toddler development, busy boards, fine motor skills, screen-free play, and practical life learning." />
    <meta property="twitter:image" content={ogImage} />
  </head>

  <body>
    <AnnouncementBar />
    <Header />

    <main>
      <header class="blogs-hero">
        <p class="eyebrow">Jagsy Joy Blog</p>
        <h1>Playful insights for parents.</h1>
        <p class="hero-text">
          Explore tips for screen-free play, early learning, and building practical life skills with your toddler.
        </p>
      </header>

      <div class="container">
        <div class="blogs-grid">
          {blogPosts.map((post) => (
            <article class="blog-preview-card">
              <div class="card-image-wrap">
                <img src={post.image} alt={post.title} />
                <div class="card-badge">{post.badge}</div>
              </div>
              <div class="card-content">
                <p class="card-meta">{post.meta}</p>
                <h2>{post.title}</h2>
                <p class="card-excerpt">
                  {post.excerpt}
                </p>
                <a href={post.link} class="read-more">Read Article</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #17204a;
    background: #eafbff;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at 10% 10%, rgba(0, 200, 255, 0.08), transparent 30%),
      radial-gradient(circle at 90% 4%, rgba(24, 214, 201, 0.08), transparent 26%),
      linear-gradient(180deg, #eafbff 0%, #f4fdff 50%, #eee8ff 100%);
  }

  .blogs-hero {
    padding: 210px 8% 80px;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .eyebrow {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #17204a;
    font-weight: 900;
    margin-bottom: 20px;
  }

  h1 {
    font-size: clamp(42px, 5vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.055em;
    margin: 0 0 24px;
    color: #17204a;
    font-weight: 900;
  }

  .hero-text {
    font-size: 18px;
    line-height: 1.65;
    color: #5f526b;
    max-width: 760px;
    margin: 0 auto;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 8% 120px;
    box-sizing: border-box;
  }

  .blogs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 48px;
  }

  .blog-preview-card {
    background: #ffffff;
    border: 1px solid #d1efff;
    border-radius: 36px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0, 200, 255, 0.04);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .blog-preview-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(0, 200, 255, 0.08);
  }

  .card-image-wrap {
    height: 260px;
    position: relative;
    overflow: hidden;
    background: #f4fdff;
  }

  .card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-preview-card:hover .card-image-wrap img {
    transform: scale(1.05);
  }

  .card-badge {
    position: absolute;
    top: 24px;
    left: 24px;
    background: #17204a;
    color: #ffffff;
    padding: 6px 14px;
    border-radius: 99px;
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .card-content {
    padding: 40px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-meta {
    font-size: 12px;
    font-weight: 800;
    color: #18d6c9;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .card-content h2 {
    font-size: 24px;
    line-height: 1.25;
    margin: 0 0 20px;
    color: #17204a;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  .card-excerpt {
    font-size: 16px;
    line-height: 1.65;
    color: #5f526b;
    margin-bottom: 30px;
    flex-grow: 1;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    color: #00c8ff;
    text-decoration: none;
    font-weight: 900;
    font-size: 15px;
    gap: 8px;
    transition: gap 0.2s ease;
  }

  .read-more::after {
    content: "→";
    font-size: 18px;
  }

  .read-more:hover {
    gap: 12px;
  }

  @media (max-width: 900px) {
    .blogs-hero {
      padding: 150px 6% 60px;
    }

    .blogs-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .blog-preview-card {
      max-width: 500px;
      margin: 0 auto;
    }

    .card-content {
      padding: 32px 24px;
    }

    .card-content h2 {
      font-size: 22px;
    }
  }
</style>