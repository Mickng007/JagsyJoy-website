---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';

const pageTitle = "Blogs | Jagsy Joy";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="description" content="Explore the Jagsy Joy blog for toddler learning tips, screen-free play ideas, and practical life skills." />
  </head>

  <body>
    <AnnouncementBar />
    <Header />

    <main>
      <header class="blogs-hero">
        <p class="eyebrow">JAGSY JOY BLOG</p>
        <h1>Playful insights for parents.</h1>
        <p class="hero-text">
          Explore tips for screen-free play, early learning, and building practical life skills with your toddler.
        </p>
      </header>

      <div class="container">
        <div class="blogs-grid">
          <article class="blog-preview-card">
            <div class="card-image-wrap">
              <img src="/images/blog-1.jpg" alt="Toddler playing with a busy board for screen-free learning" />
              <div class="card-badge">New Article</div>
            </div>
            <div class="card-content">
              <p class="card-meta">Toddler Learning • Screen-Free Play</p>
              <h2>Busy Boards: A Screen-Free Way to Help Toddlers Build Real-Life Skills</h2>
              <p class="card-excerpt">
                Discover how busy boards help toddlers build practical life skills, develop fine motor control, and enjoy meaningful screen-free play.
              </p>
              <a href="/blogs/busy-boards-screen-free-life-skills" class="read-more">Read Article</a>
            </div>
          </article>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, sans-serif;
    color: #17204A;
    background: #EAFBFF;
  }

  body {
    margin: 0;
    background: 
      radial-gradient(circle at 10% 10%, rgba(0, 200, 255, 0.08), transparent 30%),
      radial-gradient(circle at 90% 4%, rgba(24, 214, 201, 0.08), transparent 26%),
      linear-gradient(180deg, #EAFBFF 0%, #F4FDFF 50%, #EEE8FF 100%);
    min-height: 100vh;
  }

  .blogs-hero {
    padding: 210px 8% 80px;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .eyebrow {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #17204A;
    font-weight: 900;
    margin-bottom: 20px;
  }

  h1 {
    font-size: clamp(42px, 5vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.055em;
    margin: 0 0 24px;
    color: #17204A;
    font-weight: 900;
  }

  .hero-text {
    font-size: 16px;
    line-height: 1.7;
    color: #5f526b;
    max-width: 760px;
    margin: 0 auto;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 8% 120px;
  }

  .blogs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 48px;
  }

  .blog-preview-card {
    background: white;
    border: 1px solid #D1EFFF;
    border-radius: 36px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0, 200, 255, 0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .blog-preview-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(0, 200, 255, 0.08);
  }

  .card-image-wrap {
    height: 280px;
    position: relative;
    overflow: hidden;
  }

  .card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-preview-card:hover .card-image-wrap img {
    transform: scale(1.05);
  }

  .card-badge {
    position: absolute;
    top: 24px;
    left: 24px;
    background: #17204A;
    color: white;
    padding: 6px 14px;
    border-radius: 99px;
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .card-content {
    padding: 40px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-meta {
    font-size: 12px;
    font-weight: 800;
    color: #18D6C9;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .card-content h2 {
    font-size: 26px;
    line-height: 1.25;
    margin-bottom: 20px;
    color: #17204A;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  .card-excerpt {
    font-size: 16px;
    line-height: 1.65;
    color: #5f526b;
    margin-bottom: 30px;
    flex-grow: 1;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    color: #00C8FF;
    text-decoration: none;
    font-weight: 900;
    font-size: 15px;
    gap: 8px;
    transition: gap 0.2s ease;
  }

  .read-more::after {
    content: "→";
    font-size: 18px;
  }

  .read-more:hover {
    gap: 12px;
  }

  @media (max-width: 900px) {
    .blogs-hero {
      padding-top: 150px;
    }

    .blogs-grid {
      grid-template-columns: 1fr;
    }

    .blog-preview-card {
      max-width: 500px;
      margin: 0 auto;
    }
  }
</style>