---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Jagsy Joy",
  url: "http://localhost:4321",
  email: "qenterprises.design@gmail.com",
  description:
    "Jagsy Joy creates thoughtful learning toys for toddlers, including busy boards and screen-free learning toys.",
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Jagsy Joy",
  url: "http://localhost:4321",
  description:
    "Jagsy Joy creates thoughtful learning toys for toddlers, including busy boards and screen-free learning toys.",
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Jagsy Joy | Thoughtful Learning Toys for Toddlers</title>
    <meta
      name="description"
      content="Jagsy Joy creates thoughtful learning toys for toddlers, including busy boards and screen-free learning toys."
    />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>

  <body>
    <Header />

    <main>
      <section class="hero">
        <p class="eyebrow">Learning Through Play</p>
        <h1>Thoughtful toys for curious little hands.</h1>
        <p class="hero-text">
          Jagsy Joy creates toddler-friendly busy boards designed to support fine
          motor skills, independent play, and everyday discovery.
        </p>

        <div class="hero-actions">
          <a class="button primary" href="/products">Explore Products</a>
          <a class="button secondary" href="/about">Our Story</a>
        </div>
      </section>

      <section class="section">
        <p class="eyebrow">Featured Products</p>
        <h2>Simple, engaging, and made for everyday play.</h2>

        <div class="product-grid">
          {products.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      </section>

      <section class="section split">
        <div>
          <p class="eyebrow">Why Jagsy Joy</p>
          <h2>Playtime with purpose.</h2>
        </div>

        <p>
          Our toys are designed to make early learning feel natural, fun, and
          easy to include in everyday routines. From quiet travel activities to
          hands-on skill practice, Jagsy Joy helps children learn while they play.
        </p>
      </section>

      <section class="cta">
        <p class="eyebrow">Explore The Collection</p>
        <h2>Find a busy board for everyday learning moments.</h2>
        <a class="button primary" href="/products">Shop Products</a>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #2f2a24;
    background: #fffaf3;
  }

  body {
    margin: 0;
    background: linear-gradient(180deg, #fffaf3 0%, #f7efe4 100%);
  }

  .hero {
    min-height: 65vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 8% 90px;
    max-width: 960px;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 13px;
    font-weight: 800;
    color: #c77b4f;
  }

  h1 {
    font-size: clamp(48px, 7vw, 92px);
    line-height: 0.95;
    letter-spacing: -0.06em;
    margin: 0;
  }

  h2 {
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 0 0 24px;
  }

  .hero-text {
    font-size: 20px;
    line-height: 1.6;
    max-width: 680px;
    color: #6b6258;
    margin: 28px 0;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .button {
    display: inline-block;
    padding: 14px 22px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 800;
  }

  .primary {
    background: #2f2a24;
    color: white;
  }

  .secondary {
    background: white;
    color: #2f2a24;
    border: 1px solid #eadfce;
  }

  .section {
    padding: 80px 8%;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 430px));
    justify-content: center;
    gap: 32px;
    margin-top: 36px;
  }

  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .split p {
    color: #6b6258;
    line-height: 1.7;
    font-size: 17px;
  }

  .cta {
    text-align: center;
    background: white;
    margin: 40px 8% 80px;
    padding: 70px 8%;
    border-radius: 36px;
    border: 1px solid #eadfce;
    box-shadow: 0 18px 40px rgba(47, 42, 36, 0.08);
  }

  @media (max-width: 800px) {
    .product-grid,
    .split {
      grid-template-columns: 1fr;
    }
  }
</style>